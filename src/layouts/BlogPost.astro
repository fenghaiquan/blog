---
// [ADR-003] BlogPost 继承 BaseLayout，通过 mainClass 传递 with-toc 布局类
// Mermaid 图表通过客户端 CDN 动态加载（SSG 无法服务端渲染）
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import 'katex/dist/katex.min.css';
import '../styles/blog-post.css';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: { depth: number; slug: string; text: string }[];
	ogImage?: string;
};

const { title, description, date, image, headings = [], ogImage } = Astro.props;
const hasToc = headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0;
const articleUrl = Astro.url.toString();
const publishedDate = date instanceof Date ? date.toISOString().split('T')[0] : String(date);
const articleImage = ogImage || image || '';

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'BlogPosting',
		headline: title,
		description: description || '',
		datePublished: publishedDate,
		url: articleUrl,
		image: articleImage,
		author: {
			'@type': 'Person',
			name: '冯海泉',
		},
		publisher: {
			'@type': 'Organization',
			name: "Feng's Blog",
			url: 'https://www.fenghaiquan-ai.com',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: '首页',
				item: 'https://www.fenghaiquan-ai.com/',
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: '博客',
				item: 'https://www.fenghaiquan-ai.com/blog/',
			},
			{
				'@type': 'ListItem',
				position: 3,
				name: title,
				item: articleUrl,
			},
		],
	},
];
---

<BaseLayout {title} {description} mainClass={{ 'with-toc': hasToc }} ogImage={ogImage}>
	<div class="reading-progress" id="readingProgress" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="阅读进度"></div>
	<article>
		<a href="/blog" class="back-link" aria-label="返回博客列表">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
			<span>返回文章列表</span>
		</a>
		<div class="hero-image">
			{image && <img src={image} alt="" width="1020" height="510" />}
		</div>
		<div class="title-section">
			<h1>{title}</h1>
			<div class="article-meta">
				<div class="meta-item">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
					<FormattedDate date={date} />
				</div>
			</div>
		</div>
		<div class="prose">
			<slot />
		</div>
	</article>

	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>

	{hasToc && (
		<button class="toc-mobile-toggle" id="tocMobileToggle" onclick="toggleMobileToc()" aria-expanded="false" aria-controls="tocNav">
			<span>目录</span>
			<span class="toc-arrow">▼</span>
		</button>
	)}
	{hasToc && <TableOfContents headings={headings} />}

	<script>
		(function() {
			const headings = document.querySelectorAll('.prose h2[id]');
			const tocLinks = document.querySelectorAll('.toc a[data-section]');
			const progressBar = document.getElementById('tocProgressBar');
			const readingProgress = document.getElementById('readingProgress');

			function updateActiveSection() {
				let current = '';
				const scrollY = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const scrollPercent = Math.min(scrollY / docHeight, 1);
				const pct = Math.round(scrollPercent * 100);

				if (readingProgress) {
					readingProgress.style.width = pct + '%';
					readingProgress.setAttribute('aria-valuenow', String(pct));
				}
				if (progressBar) progressBar.style.width = pct + '%';

				headings.forEach(function(h) {
					const rect = h.getBoundingClientRect();
					if (rect.top <= 120) current = h.id;
				});

				tocLinks.forEach(function(link) {
					link.classList.toggle('active', link.getAttribute('data-section') === current);
				});
			}

			let ticking = false;
			window.addEventListener('scroll', function() {
				if (!ticking) {
					requestAnimationFrame(function() {
						updateActiveSection();
						ticking = false;
					});
					ticking = true;
				}
			});
			updateActiveSection();
		})();

		function toggleToc() {
			var nav = document.getElementById('tocNav');
			var header = nav?.querySelector('.toc-header');
			if (!nav) return;
			nav.classList.toggle('collapsed');
			header?.setAttribute('aria-expanded', String(!nav.classList.contains('collapsed')));
		}
		(window as any).toggleToc = toggleToc;

		const tocHeader = document.querySelector('.toc-header');
		if (tocHeader) {
			tocHeader.addEventListener('keydown', function(e) {
				if (e.key === 'Enter' || e.key === ' ') {
					e.preventDefault();
					toggleToc();
				}
			});
		}

		function toggleMobileToc() {
			var toc = document.getElementById('tocNav');
			var btn = document.getElementById('tocMobileToggle');
			if (!toc) return;
			toc.classList.toggle('mobile-visible');
			btn?.setAttribute('aria-expanded', String(toc.classList.contains('mobile-visible')));
		}
		(window as any).toggleMobileToc = toggleMobileToc;

		function alignTocWithTitleSeparator() {
			var titleSection = document.querySelector('.title-section');
			var toc = document.getElementById('tocNav');
			var article = document.querySelector('article');
			if (!titleSection || !toc || !article) return;
			var titleRect = titleSection.getBoundingClientRect();
			var articleRect = article.getBoundingClientRect();
			var offset = titleRect.bottom - articleRect.top;
			toc.style.marginTop = offset + 'px';
		}
		alignTocWithTitleSeparator();
		window.addEventListener('resize', alignTocWithTitleSeparator);

		const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');
		if (mermaidBlocks.length > 0) {
			mermaidBlocks.forEach((pre) => {
				const code = pre.querySelector('code');
				if (code) {
					pre.className = 'mermaid';
					pre.removeAttribute('data-language');
					pre.removeAttribute('tabindex');
					pre.removeAttribute('style');
					pre.textContent = code.textContent;
				}
			});
			const script = document.createElement('script');
			script.type = 'module';
			script.textContent = `
				import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
				mermaid.initialize({
				startOnLoad: false,
				theme: 'base',
				themeVariables: {
					primaryColor: '#FAF8F5',
					primaryTextColor: '#1C1917',
					primaryBorderColor: '#92400E',
					lineColor: '#92400E',
					secondaryColor: '#F5F5F4',
					tertiaryColor: '#FFFFFF',
					background: '#FAF8F5',
					mainBkg: '#FFFFFF',
					actorBkg: '#FFFFFF',
					actorBorder: '#92400E',
					actorTextColor: '#1C1917',
					noteBkgColor: '#FAF8F5',
					noteBorderColor: '#E7E5E4',
					arrowheadColor: '#92400E',
				}
				});
				await mermaid.run();
				document.querySelectorAll('.mermaid svg').forEach(svg => {
					svg.style.background = '#FAF8F5';
					const bgRect = svg.querySelector('rect');
					if (bgRect) bgRect.setAttribute('fill', '#FAF8F5');
				});
			`;
			document.body.appendChild(script);
		}
	</script>
</BaseLayout>
