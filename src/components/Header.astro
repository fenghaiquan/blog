---
import HeaderLink from './HeaderLink.astro';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const cooperateActive = subpath?.[0] === 'cooperate';
---

<a href="#main" class="skip-link">跳至正文</a>

<nav class="nav" role="navigation" aria-label="主导航">
	<div class="nav-inner">
		<a href="/" class="nav-brand" aria-label="冯海泉 — 首页">
			<span class="nav-brand-name">冯海泉</span>
			<span class="nav-brand-tag">AI Engineer</span>
		</a>
		<button class="nav-toggle" aria-label="菜单" aria-expanded="false" id="nav-toggle">
			<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h14M3 10h14M3 15h14"/></svg>
		</button>
		<div class="nav-links" id="navLinks">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/subscribe">Subscribe</HeaderLink>
			<a href="/cooperate" class:list={['nav-cta', cooperateActive && 'nav-cta--active']}>Cooperate</a>
		</div>
	</div>
</nav>

<style>
	.skip-link {
		position: absolute;
		top: -100%;
		left: 16px;
		background: var(--color-fg);
		color: var(--color-bg);
		padding: 8px 16px;
		border-radius: var(--radius-md);
		font-size: 14px;
		z-index: 100;
		text-decoration: none;
	}
	.skip-link:focus { top: 16px; }

	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--color-bg);
		border-bottom: 1px solid var(--color-border-soft);
	}
	.nav-inner {
		max-width: 1040px;
		margin: 0 auto;
		padding: 0 24px;
		height: 56px;
		display: flex;
		justify-content: space-between;
	}
	@media (min-width: 768px) { .nav-inner { padding: 0 32px; } }

	.nav-brand {
		display: flex;
		align-items: baseline;
		gap: 8px;
		text-decoration: none;
		align-self: center;
	}
	.nav-brand-name {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 14px;
		color: var(--color-fg);
	}
	.nav-brand-tag {
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--color-muted);
		font-weight: 500;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 24px;
		font-size: 14px;
		height: 100%;
	}

	.nav-cta {
		font-size: 12px;
		font-weight: 500;
		color: var(--color-fg-2);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 6px 12px;
		transition: all 200ms ease-out;
		letter-spacing: 0.02em;
		text-decoration: none;
	}
	.nav-cta:hover {
		background: var(--color-fg);
		color: var(--color-bg);
		border-color: var(--color-fg);
	}
	.nav-cta--active,
	.nav-cta--active:hover {
		background: var(--color-fg);
		color: var(--color-bg);
		border-color: var(--color-fg);
	}
	.nav-cta:focus-visible {
		outline: none;
		box-shadow: 0 0 0 3px var(--color-focus-ring);
	}

	.nav-toggle { display: none; }
	.nav-toggle { align-self: center; outline: none; }

	@media (max-width: 640px) {
		.nav-links { display: none; }
		.nav-toggle {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 36px;
			height: 36px;
			border: none;
			background: none;
			cursor: pointer;
			color: var(--color-muted);
			padding: 0;
		}
		.nav-links.nav-links--open {
			display: flex;
			flex-direction: column;
			position: absolute;
			top: 56px;
			left: 0;
			right: 0;
			background: var(--color-bg);
			border-bottom: 1px solid var(--color-border-soft);
			padding: 16px 24px;
			gap: 16px;
			z-index: 49;
		}
	}
</style>

<script>
	const toggle = document.getElementById('nav-toggle');
	const links = document.getElementById('navLinks');
	if (toggle && links) {
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			links.classList.toggle('nav-links--open');
		});
	}
</script>
