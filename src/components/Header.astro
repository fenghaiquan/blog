---
import HeaderLink from './HeaderLink.astro';

const { featureFlags } = Astro.locals;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const cooperateActive = subpath?.[0] === 'cooperate';
const hasNavigation = featureFlags.showHome || featureFlags.showAbout || 
                      featureFlags.showSubscribe || featureFlags.showCooperate;
---

<a href="#main" class="skip-link">跳至正文</a>

{hasNavigation && (
<nav class="nav" role="navigation" aria-label="主导航">
	<div class="nav-inner">
		<a href="/" class="nav-brand" aria-label="冯海泉 — 首页">
			<span class="nav-brand-name">冯海泉</span>
			<span class="nav-brand-tag">AI Engineer</span>
		</a>
		<button class="nav-toggle" aria-label="菜单" aria-expanded="false" id="nav-toggle">
			<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h14M3 10h14M3 15h14"/></svg>
		</button>
		<div class="nav-links" id="navLinks">
			{featureFlags.showHome && <HeaderLink href="/">Home</HeaderLink>}
			<HeaderLink href="/blog">Blog</HeaderLink>
			{featureFlags.showAbout && <HeaderLink href="/about">About</HeaderLink>}
			{featureFlags.showSubscribe && <HeaderLink href="/subscribe">Subscribe</HeaderLink>}
			{featureFlags.showCooperate && <a href="/cooperate" class:list={['nav-cta', cooperateActive && 'nav-cta--active']}>Cooperate</a>}
			<span class="nav-sep"></span>
			<div class="nav-social">
				<a href="https://github.com/fenghaiquan" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
				</a>
				<a href="https://x.com/fenghaiquan" aria-label="X" target="_blank" rel="noopener noreferrer">
					<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</a>
				<a href="/rss.xml" aria-label="RSS">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
				</a>
			</div>
		</div>
	</div>
</nav>
)}

<style>
	.skip-link {
		position: absolute;
		top: -100%;
		left: 16px;
		background: var(--color-fg);
		color: var(--color-bg);
		padding: 8px 16px;
		border-radius: var(--radius-md);
		font-size: 14px;
		z-index: 100;
		text-decoration: none;
	}
	.skip-link:focus { top: 16px; }

	.nav {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(250,248,245,0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--color-border);
	}
	.nav-inner {
		max-width: 1040px;
		margin: 0 auto;
		padding: 0 24px;
		height: 56px;
		display: flex;
		justify-content: space-between;
	}
	@media (min-width: 768px) { .nav-inner { padding: 0 32px; } }

	.nav-brand {
		display: flex;
		align-items: baseline;
		gap: 8px;
		text-decoration: none;
		align-self: center;
	}
	.nav-brand-name {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 14px;
		color: var(--color-fg);
	}
	.nav-brand-tag {
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--color-muted);
		font-weight: 500;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 24px;
		font-size: 14px;
		height: 100%;
	}

	.nav-cta {
		font-size: 12px;
		font-weight: 500;
		color: var(--color-fg-2);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 6px 12px;
		transition: all 200ms ease-out;
		letter-spacing: 0.02em;
		text-decoration: none;
	}
	.nav-cta:hover {
		background: var(--color-fg);
		color: var(--color-bg);
		border-color: var(--color-fg);
	}
	.nav-cta--active,
	.nav-cta--active:hover {
		background: var(--color-fg);
		color: var(--color-bg);
		border-color: var(--color-fg);
	}
	.nav-cta:focus-visible {
		outline: none;
		box-shadow: 0 0 0 3px var(--color-focus-ring);
	}

	.nav-sep {
		width: 1px;
		height: 16px;
		background: var(--color-border);
	}

	.nav-social {
		display: flex;
		gap: 0.25rem;
	}
	.nav-social a {
		width: 30px;
		height: 30px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		color: var(--color-muted);
		transition: color 0.2s, background 0.2s;
	}
	.nav-social a:hover {
		color: var(--color-accent);
		background: rgba(146,64,14,0.06);
	}
	.nav-social svg {
		width: 16px;
		height: 16px;
	}

	.nav-toggle { display: none; }
	.nav-toggle { align-self: center; outline: none; }

	@media (max-width: 640px) {
		.nav-links { display: none; }
		.nav-toggle {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 36px;
			height: 36px;
			border: none;
			background: none;
			cursor: pointer;
			color: var(--color-muted);
			padding: 0;
		}
		.nav-links.nav-links--open {
			display: flex;
			flex-direction: column;
			position: absolute;
			top: 56px;
			left: 0;
			right: 0;
			background: var(--color-bg);
			border-bottom: 1px solid var(--color-border);
			padding: 16px 24px;
			gap: 16px;
			z-index: 49;
		}
		.nav-links.nav-links--open .nav-sep {
			display: none;
		}
		.nav-links.nav-links--open .nav-social {
			gap: 0.375rem;
		}
	}
</style>

<script>
	const toggle = document.getElementById('nav-toggle');
	const links = document.getElementById('navLinks');
	if (toggle && links) {
		toggle.addEventListener('click', () => {
			const expanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', String(!expanded));
			links.classList.toggle('nav-links--open');
		});
	}
</script>
