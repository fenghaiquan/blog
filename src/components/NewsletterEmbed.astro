---
const beehiivFormId = import.meta.env.BEEHIIV_FORM_ID;
---

{beehiivFormId && (
  <section class="newsletter-container">
    <iframe
      src={`https://embeds.beehiiv.com/${beehiivFormId}?slim=true`}
      data-test-id="beehiiv-embed"
      frameBorder="0"
      scrolling="no"
      style="width: 100%; height: 200px; border-radius: 8px;"
    ></iframe>
  </section>
)}

<style>
  .newsletter-container {
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid rgb(var(--gray-light, 220 220 220));
    border-radius: 12px;
    background: rgb(var(--gray-light, 245 245 245) / 0.5);
  }
</style>
