---
const today = new Date();
---

<footer class="footer">
	<div class="container footer-inner">
		<span class="footer-text">&copy; {today.getFullYear()} 冯海泉. All rights reserved.</span>
		<div class="footer-links">
			<a href="https://github.com/fenghaiquan" class="footer-link" aria-label="GitHub" target="_blank" rel="noopener">
				<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
			</a>
			<a href="https://x.com/OttoFoong" class="footer-link" aria-label="X (Twitter)" target="_blank" rel="noopener">
				<svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor"><path d="M11.02 0H13.2L8.45 5.42 14 12.5H9.67L6.26 8.1 2.36 12.5H.18l5.08-5.8L0 .12h4.44l3.08 4.06L11.02 0zm-.77 11.22h1.21L4.63 1.28H3.33l6.92 9.94z"/></svg>
			</a>
			<a href="/rss.xml" class="footer-link" aria-label="RSS Feed">
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="2.5" cy="11.5" r="1.5" fill="currentColor" stroke="none"/><path d="M1 7a6 6 0 016 6M1 1a12 12 0 0112 12"/></svg>
			</a>
		</div>
		<span class="footer-mono">Built with code, not PPT.</span>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
	}
	.footer-inner {
		padding: 28px 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16px;
	}
	@media (min-width: 768px) {
		.footer-inner {
			flex-direction: row;
			justify-content: space-between;
		}
	}
	.footer-text {
		font-size: 12px;
		color: var(--color-muted);
	}
	.footer-mono {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--color-muted);
	}
	.footer-links {
		display: flex;
		align-items: center;
		gap: 16px;
	}
	.footer-link {
		color: var(--color-muted);
		transition: color 200ms ease-out;
	}
	.footer-link:hover {
		color: var(--color-fg);
	}
	.footer-link:focus-visible {
		outline: none;
		box-shadow: 0 0 0 3px var(--color-focus-ring);
		border-radius: 2px;
	}
</style>
