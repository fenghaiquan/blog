---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="订阅 - 冯海泉" description="订阅 Newsletter，每周 AI 洞见直达邮箱" />
	</head>
	<body class="bg-bg font-sans text-fg-2 antialiased">
		<Header />
		<main id="main" class="max-w-5xl mx-auto px-6 md:px-8 py-16 md:py-24">
			<div class="text-center">
				<h1 class="text-3xl md:text-4xl font-bold text-fg tracking-tight mb-4">订阅 Newsletter</h1>
				<p class="text-muted text-base md:text-lg mb-8">每周 AI 洞见直达邮箱</p>
				<a href="https://fenghaiquan.beehiiv.com/" target="_blank" rel="noopener" class="nav-cta">
					前往订阅 →
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
